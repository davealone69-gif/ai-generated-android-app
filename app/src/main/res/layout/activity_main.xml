<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#101420">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DroidCraft Timer"
        android:textColor="#00E5FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <ImageButton
            android:id="@+id/btnColorPicker"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_menu_edit"
            android:backgroundTint="#2D3446"
            android:contentDescription="Color Picker"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnSoundToggle"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:text="Sound: ON"
            android:backgroundTint="#2D3446" />
    </LinearLayout>

    <Button
        android:id="@+id/btnStartTimer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Start Countdown"
        android:textColor="#101420"
        android:backgroundTint="#00E5FF"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

</LinearLayout>