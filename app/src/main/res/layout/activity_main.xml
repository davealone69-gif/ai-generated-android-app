<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#101420">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dynamic Timer Hub"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/countdownDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textColor="#00E5FF"
        android:textSize="64sp"
        android:textStyle="monospace"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnStartTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Countdown"
        android:backgroundTint="#00E5FF"
        android:textColor="#101420"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select UI Theme"
        android:textColor="#888888"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnColorRed"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="#FF5252"
            android:layout_marginEnd="16dp" />

        <ImageButton
            android:id="@+id/btnColorGreen"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="#69F0AE"
            android:layout_marginEnd="16dp" />

        <ImageButton
            android:id="@+id/btnColorBlue"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="#448AFF" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/toggleSound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Sound Effects"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"
        android:checked="true" />

</LinearLayout>