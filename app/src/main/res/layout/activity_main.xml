<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#0F172A">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DroidCraft Timer"
        android:textColor="#38BDF8"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:textStyle="monospace"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnSoundToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio FX" />
    </LinearLayout>

    <View
        android:id="@+id/colorPreview"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="#38BDF8"
        android:layout_marginBottom="24dp"
        android:elevation="8dp" />

    <Button
        android:id="@+id/btnPickColor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Customize Theme Color"
        android:backgroundTint="#1E293B"
        android:textColor="#FFFFFF" />

</LinearLayout>