<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#101420">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DroidCraft Timer"
        android:textColor="#00E5FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="64sp"
        android:textStyle="monospace"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnSoundToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SFX On" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pick Theme Color"
        android:textColor="#88FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/colorPickerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E2538"
        android:padding="8dp">

        <View
            android:id="@+id/colorCyan"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#00E5FF"
            android:layout_margin="8dp" />

        <View
            android:id="@+id/colorPink"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#FF4081"
            android:layout_margin="8dp" />

        <View
            android:id="@+id/colorLime"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#B2FF59"
            android:layout_margin="8dp" />
    </LinearLayout>

</LinearLayout>