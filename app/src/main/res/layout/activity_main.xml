<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#101420">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dynamic Timer"
        android:textColor="#E0E0E0"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/countdownDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#00E5FF"
        android:textSize="72sp"
        android:textStyle="monospace"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnColorPicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Color"
            android:backgroundTint="#37474F"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnSoundEffect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Play Sound"
            android:backgroundTint="#37474F" />

    </LinearLayout>

    <Button
        android:id="@+id/btnStartTimer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="START COUNTDOWN"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#00E5FF"
        android:textColor="#101420"
        android:layout_marginTop="24dp" />

</LinearLayout>