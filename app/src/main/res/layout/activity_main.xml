<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#121212">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DroidCraft Timer"
        android:textColor="#BB86FC"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/timerDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start"
            android:backgroundTint="#03DAC5"
            android:textColor="#000000"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset"
            android:backgroundTint="#CF6679"
            android:textColor="#000000" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accent Color"
        android:textColor="#888888"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/colorPickerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1E1E1E"
        android:padding="16dp">

        <View
            android:id="@+id/colorOption1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#BB86FC"
            android:layout_margin="8dp" />

        <View
            android:id="@+id/colorOption2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#03DAC5"
            android:layout_margin="8dp" />

        <View
            android:id="@+id/colorOption3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#CF6679"
            android:layout_margin="8dp" />
    </LinearLayout>

    <Switch
        android:id="@+id/switchSound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sound Effects"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"
        android:checked="true"
        tools:ignore="UseSwitchCompatOrMaterialXml" />
</LinearLayout>