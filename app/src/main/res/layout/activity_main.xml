<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#121212">

    <TextView
        android:id="@+id/titleHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focus Timer"
        android:textColor="#BB86FC"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <TextView
        android:id="@+id/countdownDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnSound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toggle Sound" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Theme Color Picker"
        android:textColor="#808080"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/colorPickerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <View
            android:id="@+id/colorOption1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#FF5252"
            android:layout_margin="8dp" />

        <View
            android:id="@+id/colorOption2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#03DAC5"
            android:layout_margin="8dp" />

        <View
            android:id="@+id/colorOption3"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#BB86FC"
            android:layout_margin="8dp" />
    </LinearLayout>

</LinearLayout>